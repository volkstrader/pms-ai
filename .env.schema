# pms-ai — environment schema (varlock). Documents required env var NAMES only.
# No secret VALUES live here. Resolve at runtime with one of:
#   varlock run -- pms-ai <cmd>
#   infisical run -- pms-ai <cmd>
#
# pms-ai code reads os.environ only; it never stores secrets.

# @required @sensitive
# Token pms-ai uses to authenticate against your backend / services.
PMS_AI_TOKEN=
